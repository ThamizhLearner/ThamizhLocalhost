{{define "ActivityPanel"}}
   <h1>Syntax composition analysis</h1>
   <p style="font-size:1.5em;font-weight:bold;font-family:courier;color:orangered">[ Status: Experimental ]</p>
   <br/>

   <form method="post" style="font-size:2em">
      <input type="text" name="inpStr" required style="font-size:inherit"/>
      <input type="submit" value="Deconstruct" style="font-size:inherit;font-family:inherit"/>
   </form>

   {{if .ResStrs}}
      <div>
         <span style="font-size:3em">{{.InpStr}}</span> <br/>
         {{range .ResStrs}}
           <span style="font-size:2em">{{.}}</span> <br/>
         {{end}}
         <br/>
      </div>
   {{else}}
      <p>Usage example: Type in "மரங்கள்" to see its composition</p>
   {{end}}

{{end}}
