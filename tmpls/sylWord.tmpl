{{define "ActivityPanel"}}
   <h1>தமிழ் word syllabification</h1>
   <br/>

   <form method="post" style="font-size:1.5em">
      <input type="text" name="inpStr" required style="font-size:inherit"/>
      <input type="submit" value="Syllabify" style="font-size:inherit;font-family:inherit"/>
   </form>

   {{if .SylStr}}
      <div>
         <br/>
         <span style="font-size:2em">{{.InpStr}}</span> <br/>
         <span>Letters: {{.LetterCount}}</span> <br/>
         <span style="font-size:2em">{{.SylStr}}</span> <br/>
         <span>Syllabic sounds: {{.SylCount}}</span>
      </div>

      <br/> <br/>
      <div class="mermaid">
         {{.Graph}}
      </div>
   {{else}}
      <p><span style="font-weight:bold">Usage example:</span>
      Type in "<span style="font-weight:bold">இலக்கணம்</span>" to see its syllabified form.
      </p>
   {{end}}
{{end}}
